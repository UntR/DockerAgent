# ─────────────────────────────────────────────────────────────
# DockerAgent 环境变量配置
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# LLM 提供商（支持在 UI 设置页面动态切换，这里是初始默认值）
# 可选：anthropic / openai / custom
LLM_PROVIDER=anthropic

# Anthropic (Claude) API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI / 兼容接口 API Key（DeepSeek、MiniMax、Kimi 等均可）
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# GitHub Token（可选，用于从 GitHub 抓取 .env.example / compose 文件，提高速率限制）
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# 后端端口（本地开发用，默认 8088）
BACKEND_PORT=8088

# SQLite 数据库路径（Docker 部署时建议挂载到 /data）
DB_PATH=/data/docker_agent.db

# ─────────────────────────────────────────────────────────────
# 安全配置（公网暴露时强烈建议设置）
# ─────────────────────────────────────────────────────────────

# API 访问令牌（设置后，所有 /api/* 请求均需携带）
# HTTP：请求头 Authorization: Bearer <token>  或  X-API-Key: <token>
# WebSocket：连接 URL 末尾加 ?token=<token>
# 留空则跳过鉴权（仅推荐纯内网环境）
ACCESS_TOKEN=

# 允许的跨域来源（逗号分隔），留空默认为 * （无凭证跨域）
# 公网部署示例：ALLOWED_ORIGINS=https://myserver.com,https://www.myserver.com
ALLOWED_ORIGINS=

# ─────────────────────────────────────────────────────────────
# 部署超时配置
# ─────────────────────────────────────────────────────────────

# 镜像拉取超时（秒），0 = 不限时
# 部署大型镜像（vLLM、CUDA 等）时建议设置为 0
COMPOSE_PULL_TIMEOUT=0

# 容器启动超时（秒），0 = 不限时
COMPOSE_UP_TIMEOUT=120
